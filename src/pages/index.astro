---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";

const projects = await getCollection("projects");
---

<Layout title="Game Dev Portfolio">
    <main class="page">
        <section class="home-hero">
            <h1>Your Name</h1>
            <p>Game developer focused on gameplay systems, level design, and interactive worlds.</p>
        </section>

        <section>
            <h2>Projects</h2>

            <div class="project-grid">
                {projects.map((project) => (
                        <a class="game-card" href={`/projects/${project.data.slug}/`}>
                            <img src={project.data.thumbnail} alt="cant see this" />

                            <div class="game-card-content">
                                <h3>{project.data.title}</h3>
                                <p>{project.data.description}</p>
                                <span>{project.data.engine}</span>
                            </div>
                        </a>
                ))}
            </div>
        </section>
    </main>
</Layout>