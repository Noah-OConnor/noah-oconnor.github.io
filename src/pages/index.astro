---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import FeaturedProjectCarousel from "../components/FeaturedProjectCarousel.astro";

const projects = await getCollection("projects");

const featuredProjectSlugs = [
    "example-project",
    "crimson-knight",
];

const featuredProjects = featuredProjectSlugs
    .map((slug) => projects.find((project) => project.data.slug === slug))
    .filter((project) => project !== undefined);
---

<Layout title="Game Dev Portfolio">
    <main class="page">
        <section class="home-hero">
            <h1>Your Name</h1>
            <p>Game developer focused on gameplay systems, level design, and interactive worlds.</p>
        </section>

        <FeaturedProjectCarousel projects={featuredProjects} />

        <section>
            <h2>Projects</h2>

            <div class="project-grid">
                {projects.map((project) => (
                        <a class="game-card" href={`/projects/${project.slug}/`}>
                            <img src={project.data.thumbnail} alt={`${project.data.title} thumbnail`} />

                            <div class="game-card-content">
                                <h3>{project.data.title}</h3>
                                <p>{project.data.description}</p>
                                <span>{project.data.engine}</span>
                            </div>
                        </a>
                ))}
            </div>
        </section>
    </main>
</Layout>