---
import type { CollectionEntry } from "astro:content";

type Project = CollectionEntry<"projects">;
type ProjectSection = Project["data"]["sections"][number];
type ProjectSectionItem = ProjectSection["items"][number];

interface Props {
    sections: ProjectSection[];
}

const { sections = [] } = Astro.props as Props;
---

{sections.length > 0 && (
<section class="project-content-sections" aria-label="Project details">
    {sections.map((section: ProjectSection, sectionIndex: number) => (
            <article
                    class={`project-content-section ${sectionIndex === 0 ? "is-open" : ""}`}
                    data-project-content-section
            >
                <div class="project-content-section__body" data-project-content-body>
                    <h2 class="project-content-section__title">{section.title}</h2>

                    {section.items.map((item: ProjectSectionItem) => (
                            <>
                                {item.type === "text" && (
                                        <p class="project-content-section__text">
                                            {item.body}
                                        </p>
                                )}

                                {(item.type === "image" || item.type === "gif") && (
                                        <figure class="project-content-section__media">
                                            <img src={item.src} alt={item.alt ?? ""} loading="lazy" />

                                            {item.caption && (
                                                    <figcaption>{item.caption}</figcaption>
                                            )}
                                        </figure>
                                )}
                            </>
                    ))}
                </div>

                <button
                        class="project-content-section__toggle"
                        type="button"
                        data-project-content-toggle
                        aria-expanded={sectionIndex === 0 ? "true" : "false"}
                >
        <span class="project-content-section__toggle-text">
            {sectionIndex === 0 ? "Show Less" : "Read More"}
        </span>
                </button>
            </article>
    ))}
</section>

<script>
    const sections = Array.from(
        document.querySelectorAll<HTMLElement>("[data-project-content-section]")
    );

    sections.forEach((section) => {
        const toggle = section.querySelector<HTMLButtonElement>("[data-project-content-toggle]");
        const toggleText = section.querySelector<HTMLElement>(".project-content-section__toggle-text");

        toggle?.addEventListener("click", () => {
            const isOpen = section.classList.toggle("is-open");

            toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");

            if (toggleText) {
                toggleText.textContent = isOpen ? "Show Less" : "Read More";
            }
        });
    });
</script>
    )}