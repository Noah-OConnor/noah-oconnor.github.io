---
import type { CollectionEntry } from "astro:content";

type Project = CollectionEntry<"projects">;

interface Props {
    projects: Project[];
}

const { projects = [] } = Astro.props as Props;
const projectPreviews = projects.map((project) => ({
    slug: project.data.slug,
    coverImage: project.data.coverImage,
    title: project.data.title,
}));
---

{projects.length > 0 && (
<section class="featured-carousel" aria-label="Featured projects">
    <div class="featured-carousel__header">
        <h2>Featured Projects</h2>
    </div>

    <div class="featured-carousel__viewport" data-featured-carousel>
        {projects.length > 1 && (
                <>
                    <button
                            class="featured-carousel__peek featured-carousel__peek--prev"
                            type="button"
                            data-carousel-peek-prev
                            aria-label="Previous featured project"
                    >
                        <img
                                src={projects[projects.length - 1].data.coverImage}
                                alt=""
                                data-carousel-peek-prev-img
                        />
                        <span class="featured-carousel__peek-arrow" aria-hidden="true">‹</span>
                    </button>

                    <button
                            class="featured-carousel__peek featured-carousel__peek--next"
                            type="button"
                            data-carousel-peek-next
                            aria-label="Next featured project"
                    >
                        <img
                                src={projects[1].data.coverImage}
                                alt=""
                                data-carousel-peek-next-img
                        />
                        <span class="featured-carousel__peek-arrow" aria-hidden="true">›</span>
                    </button>
                </>
        )}

        {projects.map((project, index) => {
            const coverImage = project.data.coverImage;
            const screenshots = project.data.media
                .filter((item) => item.type === "image")
                .slice(0, 4);

            const tags = [
                project.data.engine,
                project.data.language,
                project.data.perspective,
                project.data.genre,
                project.data.role,
            ].filter(Boolean);

            return (
                    <article
                            class={`featured-slide ${index === 0 ? "is-active" : ""}`}
                            data-slide
                            aria-hidden={index === 0 ? "false" : "true"}
                    >
                        <a class="featured-slide__link" href={`/projects/${project.data.slug}/`}>
                            <div class="featured-slide__cover">
                                <img src={coverImage} alt={`${project.data.title} cover image`} />
                            </div>

                            <div class="featured-slide__details">
                                <h3>{project.data.title}</h3>

                                <div class="featured-slide__screenshots">
                                    {screenshots.map((screenshot) => (
                                            <img src={screenshot.imgSrc} alt="no src" loading="lazy" />
                                    ))}
                                </div>

                                <p class="featured-slide__description">
                                    {project.data.description}
                                </p>

                                <div class="featured-slide__tags" aria-label="Project tags">
                                    {tags.map((tag) => (
                                            <span>{tag}</span>
                                    ))}
                                </div>
                            </div>
                        </a>
                    </article>
            );
        })}

        {projects.length > 1 && (
                <>
                    <div class="featured-carousel__dots" aria-label="Featured project navigation">
                        {projects.map((project, index) => (
                                <button
                                        type="button"
                                        class={index === 0 ? "is-active" : ""}
                                        data-carousel-dot={index}
                                        aria-label={`Show ${project.data.title}`}
                                />
                        ))}
                    </div>
                </>
        )}
    </div>
</section>

<script define:vars={{ projectPreviews }}>
    const carousel = document.querySelector("[data-featured-carousel]");

    if (carousel) {
        const slides = Array.from(carousel.querySelectorAll("[data-slide]"));
        const dots = Array.from(carousel.querySelectorAll("[data-carousel-dot]"));
        
        const prevButton = carousel.querySelector("[data-carousel-peek-prev]");
        const nextButton = carousel.querySelector("[data-carousel-peek-next]");

        const prevPeek = carousel.querySelector("[data-carousel-peek-prev]");
        const nextPeek = carousel.querySelector("[data-carousel-peek-next]");
        
        const prevPeekImg = carousel.querySelector("[data-carousel-peek-prev-img]");
        const nextPeekImg = carousel.querySelector("[data-carousel-peek-next-img]");

        let currentIndex = 0;
        let isPaused = false;
        let intervalId;

        let touchStartX = 0;
        let touchStartY = 0;
        let touchEndX = 0;
        let touchEndY = 0;
        
        function updatePeekPanels() {
            if (projectPreviews.length <= 1) return;

            const previousIndex =
                (currentIndex - 1 + projectPreviews.length) % projectPreviews.length;

            const nextIndex =
                (currentIndex + 1) % projectPreviews.length;

            const previousProject = projectPreviews[previousIndex];
            const nextProject = projectPreviews[nextIndex];

            if (prevPeek && prevPeekImg) {
                prevPeek.setAttribute("aria-label", `Show ${previousProject.title}`);
                prevPeekImg.src = previousProject.coverImage;
                prevPeekImg.alt = `${previousProject.title} cover image`;
            }

            if (nextPeek && nextPeekImg) {
                nextPeek.setAttribute("aria-label", `Show ${nextProject.title}`);
                nextPeekImg.src = nextProject.coverImage;
                nextPeekImg.alt = `${nextProject.title} cover image`;
            }
        }

        function showSlide(nextIndex) {
            if (slides.length === 0) return;

            currentIndex = (nextIndex + slides.length) % slides.length;

            slides.forEach((slide, index) => {
                const isActive = index === currentIndex;
                slide.classList.toggle("is-active", isActive);
                slide.setAttribute("aria-hidden", isActive ? "false" : "true");
            });

            dots.forEach((dot, index) => {
                dot.classList.toggle("is-active", index === currentIndex);
            });

            updatePeekPanels();
        }

        function nextSlide() {
            showSlide(currentIndex + 1);
        }

        function previousSlide() {
            showSlide(currentIndex - 1);
        }

        function stopAutoplay() {
            if (intervalId !== undefined) {
                window.clearInterval(intervalId);
                intervalId = undefined;
            }
        }

        function startAutoplay() {
            if (slides.length <= 1) return;

            stopAutoplay();

            intervalId = window.setInterval(() => {
                if (!isPaused) {
                    nextSlide();
                }
            }, 6000);
        }

        function handleSwipe() {
            const deltaX = touchEndX - touchStartX;
            const deltaY = touchEndY - touchStartY;

            const minimumSwipeDistance = 50;
            const isMostlyHorizontal = Math.abs(deltaX) > Math.abs(deltaY);

            if (!isMostlyHorizontal) return;
            if (Math.abs(deltaX) < minimumSwipeDistance) return;

            if (deltaX < 0) {
                nextSlide();
            } else {
                previousSlide();
            }
        }

        carousel.addEventListener("mouseenter", () => {
            isPaused = true;
        });

        carousel.addEventListener("mouseleave", () => {
            isPaused = false;
        });

        carousel.addEventListener("focusin", () => {
            isPaused = true;
        });

        carousel.addEventListener("focusout", () => {
            isPaused = false;
        });

        prevButton?.addEventListener("click", previousSlide);
        nextButton?.addEventListener("click", nextSlide);

        dots.forEach((dot, index) => {
            dot.addEventListener("click", () => {
                showSlide(index);
            });
        });

        carousel.addEventListener(
            "touchstart",
            (event) => {
                const touch = event.changedTouches[0];

                touchStartX = touch.clientX;
                touchStartY = touch.clientY;
            },
            { passive: true }
        );

        carousel.addEventListener(
            "touchend",
            (event) => {
                const touch = event.changedTouches[0];

                touchEndX = touch.clientX;
                touchEndY = touch.clientY;

                handleSwipe();
            },
            { passive: true }
        );

        showSlide(0);
        startAutoplay();
    }
</script>
    )}