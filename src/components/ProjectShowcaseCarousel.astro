---
import type { CollectionEntry } from "astro:content";

type Project = CollectionEntry<"projects">;
type ProjectMedia = Project["data"]["media"][number];

interface Props {
    project: Project;
}

const { project } = Astro.props as Props;

const fallbackMedia: ProjectMedia[] = [
    {
        type: "image",
        imgSrc: project.data.coverImage,
        alt: `${project.data.title} cover image`,
    },
];

const media: ProjectMedia[] =
    project.data.media.length > 0 ? project.data.media : fallbackMedia;

const tags = [
    project.data.engine,
    project.data.language,
    project.data.perspective,
    project.data.genre,
    project.data.role,
].filter((tag): tag is string => Boolean(tag));

function getYouTubeApiSrc(src: string) {
    const url = new URL(src);

    url.searchParams.set("enablejsapi", "1");
    url.searchParams.set("playsinline", "1");

    return url.toString();
}
---

<section class="project-showcase" data-project-showcase>
    <div class="project-showcase__header">
        <p class="project-showcase__breadcrumb">
            <a href="/">All Projects</a>
            <span>›</span>
            <span>{project.data.genre ?? "Game Project"}</span>
            <span>›</span>
            <strong>{project.data.title}</strong>
        </p>

        <h1>{project.data.title}</h1>
    </div>

    <div class="project-showcase__layout">
        <div class="project-showcase__media-column">
            <div class="project-showcase__stage">
                {media.map((item: ProjectMedia, index: number) => (
                        <div
                                class={`project-showcase__slide ${index === 0 ? "is-active" : ""}`}
                                data-project-slide
                                data-media-type={item.type}
                                aria-hidden={index === 0 ? "false" : "true"}
                        >
                            {item.type === "image" ? (
                                    <img src={item.imgSrc} alt={item.alt ?? ""} />
                            ) : (
                                    <iframe
                                            class="project-showcase__youtube"
                                            src={getYouTubeApiSrc(item.src)}
                                            title={item.title ?? `${project.data.title} video`}
                                            data-video-index={index}
                                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                            allowfullscreen
                                    />
                            )}
                        </div>
                ))}

                {media.length > 1 && (
                        <>
                            <button
                                    class="project-showcase__stage-button project-showcase__stage-button--prev"
                                    type="button"
                                    data-project-prev
                                    aria-label="Previous media"
                            ></button>

                            <button
                                    class="project-showcase__stage-button project-showcase__stage-button--next"
                                    type="button"
                                    data-project-next
                                    aria-label="Next media"
                            ></button>
                        </>
                )}
            </div>

            {media.length > 0 && (
                    <div class="project-showcase__thumbs" aria-label="Project media thumbnails">
                        {media.map((item: ProjectMedia, index: number) => {
                            const thumbSrc = item.imgSrc;

                            return (
                                    <button
                                            class={`project-showcase__thumb ${index === 0 ? "is-active" : ""}`}
                                            type="button"
                                            data-project-thumb={index}
                                            aria-label={`Show media ${index + 1}`}
                                    >
                                        <img src={thumbSrc} alt="" loading="lazy" />

                                        {item.type === "video" && (
                                                <span class="project-showcase__play-icon" aria-hidden="true">
                        ▶
                    </span>
                                        )}
                                    </button>
                            );
                        })}
                    </div>
            )}
        </div>

        <aside class="project-showcase__info">
            <img
                    class="project-showcase__capsule"
                    src={project.data.coverImage}
                    alt={`${project.data.title} cover image`}
            />

            <p class="project-showcase__description">
                {project.data.description}
            </p>

            <dl class="project-showcase__facts">
                <div>
                    <dt>Engine</dt>
                    <dd>{project.data.engine}</dd>
                </div>

                {project.data.language && (
                        <div>
                            <dt>Language</dt>
                            <dd>{project.data.language}</dd>
                        </div>
                )}

                {project.data.perspective && (
                        <div>
                            <dt>Perspective</dt>
                            <dd>{project.data.perspective}</dd>
                        </div>
                )}

                {project.data.genre && (
                        <div>
                            <dt>Genre</dt>
                            <dd>{project.data.genre}</dd>
                        </div>
                )}

                <div>
                    <dt>Role</dt>
                    <dd>{project.data.role}</dd>
                </div>

                <div>
                    <dt>Status</dt>
                    <dd>{project.data.status}</dd>
                </div>
            </dl>

            <div class="project-showcase__tags" aria-label="Project tags">
                {tags.map((tag: string) => (
                        <span>{tag}</span>
                ))}
            </div>

            
        </aside>
    </div>
</section>

<script>
    const showcase = document.querySelector<HTMLElement>("[data-project-showcase]");
    
    if (showcase) {
        const slides = Array.from(
            showcase.querySelectorAll<HTMLElement>("[data-project-slide]")
        );

        const thumbsContainer = showcase.querySelector<HTMLElement>(".project-showcase__thumbs");

        const thumbs = Array.from(
            showcase.querySelectorAll<HTMLButtonElement>("[data-project-thumb]")
        );

        const prevButton = showcase.querySelector<HTMLButtonElement>("[data-project-prev]");
        const nextButton = showcase.querySelector<HTMLButtonElement>("[data-project-next]");

        const youtubeIframes = Array.from(
            showcase.querySelectorAll<HTMLIFrameElement>(".project-showcase__youtube")
        );

        const youtubePlayers = new Map<number, any>();

        const win = window as Window & {
            YT?: any;
            onYouTubeIframeAPIReady?: () => void;
        };
        
        let currentIndex = 0;
        let isPaused = false;
        let intervalId: number | undefined;

        let touchStartX = 0;
        let touchStartY = 0;
        let touchEndX = 0;
        let touchEndY = 0;

        function scrollActiveThumbnailIntoView(behavior: ScrollBehavior = "smooth") {
            if (!thumbsContainer) return;

            const activeThumb = thumbs[currentIndex];
            const firstThumb = thumbs[0];

            if (!activeThumb || !firstThumb) return;

            const thumbsContainerStyles = window.getComputedStyle(thumbsContainer);
            const columnGap = Number.parseFloat(thumbsContainerStyles.columnGap) || 6;

            const thumbWidth = activeThumb.getBoundingClientRect().width;
            const thumbStep = thumbWidth + columnGap;

            const targetScrollLeft = (currentIndex - 1) * thumbStep;

            thumbsContainer.scrollTo({
                left: Math.max(0, targetScrollLeft),
                behavior,
            });
        }

        function isCurrentSlideVideo() {
            const activeSlide = slides[currentIndex];
            return activeSlide?.dataset.mediaType === "video";
        }

        function loadYouTubeApi(): Promise<any> {
            return new Promise((resolve) => {
                if (win.YT?.Player) {
                    resolve(win.YT);
                    return;
                }

                const existingScript = document.querySelector(
                    "script[src='https://www.youtube.com/iframe_api']"
                );

                if (!existingScript) {
                    const script = document.createElement("script");
                    script.src = "https://www.youtube.com/iframe_api";
                    document.head.appendChild(script);
                }

                const previousCallback = win.onYouTubeIframeAPIReady;

                win.onYouTubeIframeAPIReady = () => {
                    if (typeof previousCallback === "function") {
                        previousCallback();
                    }

                    resolve(win.YT);
                };
            });
        }

        async function setupYouTubePlayers() {
            if (youtubeIframes.length === 0) return;

            const YT = await loadYouTubeApi();

            youtubeIframes.forEach((iframe: HTMLIFrameElement) => {
                const videoIndex = Number(iframe.dataset.videoIndex);

                const player = new YT.Player(iframe, {
                    events: {
                        onReady: (event: any) => {
                            event.target.mute();

                            if (videoIndex === currentIndex) {
                                event.target.playVideo();
                            }
                        },

                        onStateChange: (event: any) => {
                            if (
                                event.data === YT.PlayerState.ENDED &&
                                videoIndex === currentIndex
                            ) {
                                nextSlide();
                            }
                        },
                    },
                });

                youtubePlayers.set(videoIndex, player);
            });
        }

        function syncYouTubePlayback() {
            youtubePlayers.forEach((player: any, index: number) => {
                if (!player || typeof player.playVideo !== "function") return;

                if (index === currentIndex) {
                    player.mute();
                    player.playVideo();
                } else if (typeof player.pauseVideo === "function") {
                    player.pauseVideo();
                }
            });
        }

        function showSlide(nextIndex: number, behavior: ScrollBehavior = "smooth") {
            if (slides.length === 0) return;

            currentIndex = (nextIndex + slides.length) % slides.length;

            slides.forEach((slide: HTMLElement, index: number) => {
                const isActive = index === currentIndex;
                slide.classList.toggle("is-active", isActive);
                slide.setAttribute("aria-hidden", isActive ? "false" : "true");
            });

            thumbs.forEach((thumb: HTMLButtonElement, index: number) => {
                thumb.classList.toggle("is-active", index === currentIndex);
            });

            scrollActiveThumbnailIntoView(behavior);
            syncYouTubePlayback();
        }

        function nextSlide() {
            showSlide(currentIndex + 1);
        }

        function previousSlide() {
            showSlide(currentIndex - 1);
        }

        function stopAutoplay() {
            if (intervalId !== undefined) {
                window.clearInterval(intervalId);
                intervalId = undefined;
            }
        }

        function startAutoplay() {
            if (slides.length <= 1) return;

            stopAutoplay();

            intervalId = window.setInterval(() => {
                if (!isPaused && !isCurrentSlideVideo()) {
                    nextSlide();
                }
            }, 7000);
        }

        function handleSwipe() {
            const deltaX = touchEndX - touchStartX;
            const deltaY = touchEndY - touchStartY;

            const minimumSwipeDistance = 50;
            const isMostlyHorizontal = Math.abs(deltaX) > Math.abs(deltaY);

            if (!isMostlyHorizontal) return;
            if (Math.abs(deltaX) < minimumSwipeDistance) return;

            if (deltaX < 0) {
                nextSlide();
            } else {
                previousSlide();
            }
        }

        showcase.addEventListener("mouseenter", () => {
            isPaused = true;
        });

        showcase.addEventListener("mouseleave", () => {
            isPaused = false;
        });

        showcase.addEventListener("focusin", () => {
            isPaused = true;
        });

        showcase.addEventListener("focusout", () => {
            isPaused = false;
        });

        showcase.addEventListener(
            "touchstart",
            (event) => {
                const touch = event.changedTouches[0];

                touchStartX = touch.clientX;
                touchStartY = touch.clientY;
            },
            { passive: true }
        );

        showcase.addEventListener(
            "touchend",
            (event) => {
                const touch = event.changedTouches[0];

                touchEndX = touch.clientX;
                touchEndY = touch.clientY;

                handleSwipe();
            },
            { passive: true }
        );

        prevButton?.addEventListener("click", previousSlide);
        nextButton?.addEventListener("click", nextSlide);

        thumbs.forEach((thumb: HTMLButtonElement, index: number) => {
            thumb.addEventListener("click", () => {
                showSlide(index);
            });
        });

        showSlide(0, "auto");
        setupYouTubePlayers();
        startAutoplay();
    }
</script>